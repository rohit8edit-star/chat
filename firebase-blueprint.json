{
  "entities": {
    "User": {
      "title": "User",
      "description": "User profile information",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "displayName": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "photoURL": { "type": "string" },
        "about": { "type": "string" },
        "phoneNumber": { "type": "string" },
        "status": { "type": "string", "enum": ["online", "offline"] },
        "lastSeen": { "type": "string", "format": "date-time" }
      },
      "required": ["uid", "email"]
    },
    "Chat": {
      "title": "Chat",
      "description": "A conversation between two or more users",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "type": { "type": "string", "enum": ["individual", "group"] },
        "participants": {
          "type": "array",
          "items": { "type": "string" }
        },
        "lastMessage": {
          "type": "object",
          "properties": {
            "text": { "type": "string" },
            "createdAt": { "type": "string", "format": "date-time" },
            "senderId": { "type": "string" }
          }
        },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "type", "participants"]
    },
    "Message": {
      "title": "Message",
      "description": "A single message within a chat",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "senderId": { "type": "string" },
        "text": { "type": "string" },
        "mediaUrl": { "type": "string" },
        "type": { "type": "string", "enum": ["text", "image", "video", "file", "voice", "location"] },
        "createdAt": { "type": "string", "format": "date-time" },
        "status": { "type": "string", "enum": ["sent", "delivered", "read"] }
      },
      "required": ["id", "senderId", "type", "createdAt"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": { "$ref": "#/entities/User" },
      "description": "User profiles"
    },
    "/chats/{chatId}": {
      "schema": { "$ref": "#/entities/Chat" },
      "description": "Chat conversations"
    },
    "/chats/{chatId}/messages/{messageId}": {
      "schema": { "$ref": "#/entities/Message" },
      "description": "Messages within a conversation"
    }
  }
}
